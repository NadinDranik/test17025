# Порт HTTP-сервера (Nginx проксирует на этот порт)
PORT=3000

# production — включает trust proxy; COOKIE_SECURE=true только при HTTPS
NODE_ENV=production
COOKIE_SECURE=false

# Секрет сессий (сгенерируйте: openssl rand -hex 32)
SESSION_SECRET=замените-на-длинную-случайную-строку

# Учётная запись администратора (создаётся при первом запуске)
ADMIN_EMAIL=admin@gost17025.pro
ADMIN_PASSWORD=замените-на-надёжный-пароль

# Публичный URL сайта для превью ссылок (Open Graph, Twitter). Пример: http://185.39.206.48
SITE_PUBLIC_URL=https://akkred17025.ru

# Версия CSS/JS для сброса кэша браузера (при деплое ставится git-коммит)
ASSET_VERSION=

# --- Онлайн-оплата PRO (Prodamus) ---
# Включить модуль онлайн-оплаты через Prodamus
PAYMENTS_ENABLED=true

# URL платёжной формы Prodamus (например https://yourname.payform.ru/)
PRODAMUS_PAYFORM_URL=

# Секретный ключ из настроек платёжной страницы Prodamus
PRODAMUS_SECRET_KEY=

# Код интеграции SYS (согласовать с поддержкой Prodamus или оставить gost17025)
PRODAMUS_SYS=gost17025

# Демо-режим Prodamus (1 — тестовые платежи)
PRODAMUS_DEMO_MODE=0

# Тариф PRO
PRO_MONTHLY_PRICE=1000
PRO_MONTHLY_DAYS=30
