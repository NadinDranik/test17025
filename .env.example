# Порт HTTP-сервера (Nginx проксирует на этот порт)
PORT=3000

# production — включает secure-cookie и trust proxy
NODE_ENV=production

# Секрет сессий (сгенерируйте: openssl rand -hex 32)
SESSION_SECRET=замените-на-длинную-случайную-строку

# Учётная запись администратора (создаётся при первом запуске)
ADMIN_EMAIL=admin@gost17025.pro
ADMIN_PASSWORD=замените-на-надёжный-пароль
